{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(dotnet *)",
      "Bash(npm *)",
      "Bash(npx *)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git worktree remove --force*)"
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh '/home/chris/.claude/hooks/herdr-md-preview.sh'",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/chris/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "theme": "dark"
}
